# ============================================
# Configuración para XAMPP
# ============================================

# Base de Datos MySQL (XAMPP)
# Por defecto XAMPP usa usuario "root" sin contraseña
DATABASE_URL="mysql://root@localhost:3306/cafeteria_ucp"

# Si configuraste una contraseña en XAMPP, usa:
# DATABASE_URL="mysql://root:tu_password@localhost:3306/cafeteria_ucp"

# JWT Secret para autenticación (genera uno aleatorio y seguro)
JWT_SECRET=tu_jwt_secret_muy_seguro_aqui_cambiar_esto_12345

# URL base de la aplicación
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ============================================
# Configuración de correo (OPCIONAL)
# Para verificación por correo electrónico
# ============================================

# Gmail - Necesitas una "Contraseña de aplicación"
# Tutorial: https://support.google.com/accounts/answer/185833
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASSWORD=tu_contraseña_de_aplicacion_gmail

# ============================================
# Notas importantes:
# ============================================
# 1. Copia este archivo como .env en la raíz del proyecto
# 2. Reemplaza los valores de ejemplo con tus datos reales
# 3. NUNCA subas el archivo .env a GitHub
# 4. Asegúrate de que XAMPP esté corriendo antes de iniciar
