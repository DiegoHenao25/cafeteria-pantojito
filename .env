# ============================================
# Base de Datos MySQL (para Next.js con Prisma)
# ============================================
DATABASE_URL="mysql://root@localhost:3306/cafeteria_ucp"

# JWT Secret para autenticación
JWT_SECRET=tu_jwt_secret_muy_seguro_aqui_cambiar_esto_12345

# URL base de la aplicación
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ============================================
# Configuración de MySQL para Go API
# ============================================
DB_HOST=localhost:3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cafeteria_ucp

# ============================================
# Cloudinary (para subir imágenes)
# ============================================
